{
  "name": "Mesa Cheia",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Mesa Cheia",
      "onAutoForward": "openBrowserOnce",
      "visibility": "public"
    }
  },
  "postCreateCommand": "cd /workspaces/mesa-cheia && cp .env.example .env && npm install",
  "postStartCommand": "npm start",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
